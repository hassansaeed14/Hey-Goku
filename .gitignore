# =========================

# AURA .gitignore

# =========================

# -------------------------

# Python

# -------------------------

**pycache**/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# -------------------------

# Virtual Environments

# -------------------------

venv/
.venv/
env/

# -------------------------

# Environment Variables

# -------------------------

.env
.env.*

# -------------------------

# Temp / Debug / Logs

# -------------------------

tmp_*
tmp*
tmp*/
temp*/
logs/
*.log
*.out.log
*.err.log
*.pid
dev_log.txt

# -------------------------

# Memory (Private Data)

# -------------------------

memory/*.json
memory/*.jsonl
memory/*.db
memory/*.sqlite
memory/*.sqlite3
memory/*.db-journal
memory/*.sqlite3-*
memory/vector_store/
memory/vector_store_fallback.json

# -------------------------

# Security (Sensitive)

# -------------------------

security/*.json
security/*.hash
security/.secret.key

# -------------------------

# Screenshots / Artifacts

# -------------------------

screenshot_*.png
tmp*.png

# -------------------------

# OS Files

# -------------------------

.DS_Store
Thumbs.db

# -------------------------

# Editor / IDE

# -------------------------

.vscode/
.idea/

# -------------------------

# Build / Cache

# -------------------------

dist/
build/

# -------------------------

# Misc

# -------------------------

*.tmp
*.bak
# Generated files
generated/
generated/**
*.pdf
*.docx
*.pptx
*.txt
!requirements.txt

# AURA outputs
AI-*
.aider*
